AI_PROVIDER=openai
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-5.6

# Or use Gemini:
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
